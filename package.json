{
  "name": "skimd",
  "version": "0.1.3",
  "description": "Terminal markdown reader — zero install, TOC, collapse, one command.",
  "author": "Bjern Potgieter <bjern@valors.io>",
  "homepage": "https://github.com/Bjern/skimd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bjern/skimd.git"
  },
  "bugs": "https://github.com/Bjern/skimd/issues",
  "keywords": ["markdown", "terminal", "cli", "reader", "tui", "ink", "readme"],
  "type": "module",
  "bin": {
    "skimd": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "clipboardy": "^4.0.0",
    "ignore": "^5.3.2",
    "ink": "^5.0.1",
    "marked": "^12.0.2",
    "meow": "^13.2.0",
    "open": "^10.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@vitest/coverage-v8": "^4.1.4",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
